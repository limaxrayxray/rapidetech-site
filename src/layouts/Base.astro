---
import "@/styles/global.css";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import SEO from "@/components/SEO.astro";
import SchemaOrg from "@/components/SchemaOrg.astro";
import { getSiteSettings, getFaq } from "@/lib/directus";

interface Props {
  title?: string;
  description?: string;
  /** true → meta robots noindex (pages utilitaires, ex. /merci/). */
  noindex?: boolean;
  /** Q/R propres à la page (JSON-LD FAQPage) — ex. le champ faq d'un service. */
  faq?: { question: string; answer: string }[];
}

// Réglages globaux (build time). meta_title / meta_description pilotent le SEO
// par défaut ; une page peut toujours surcharger via les props title/description.
const settings = await getSiteSettings();

const {
  title = settings.meta_title,
  description = settings.meta_description,
  noindex = false,
  faq,
} = Astro.props;

// FAQPage : la page fournit ses Q/R en prop ; sinon l'accueil prend la
// collection Directus `faq` (fallback silencieux [] tant qu'elle n'existe pas).
const faqItems = faq ?? (Astro.url.pathname === "/" ? await getFaq() : []);
---

<!doctype html>
<html lang="fr-CA" class="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <SEO
      title={title}
      description={description}
      siteName={settings.company_name}
      noindex={noindex}
    />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <SchemaOrg settings={settings} faq={faqItems} />
    <!-- Fonts display critiques (le hero est above-the-fold). -->
    <link
      rel="preload"
      href="/fonts/ClashDisplay-Semibold.woff"
      as="font"
      type="font/woff"
      crossorigin
    />
    <link
      rel="preload"
      href="/fonts/GeneralSans-Regular.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />
    <!-- Gate no-JS : les états « cachés avant reveal » n'existent que sous
         html.js — sans JavaScript, tout le contenu est visible d'emblée. -->
    <script is:inline>
      document.documentElement.classList.add("js");
    </script>
  </head>
  <body>
    <!-- Spotlight vert qui suit le curseur (texture signature CIRCUIT). -->
    <div class="rt-spot" aria-hidden="true"></div>
    <Header settings={settings} />
    <slot />
    <Footer settings={settings} />

    <!-- Effets globaux CIRCUIT : suivi du pointeur (spotlight + grille du
         hero via --mx/--my) et déclenchement des reveals (body.loaded). -->
    <script is:inline>
      (function () {
        if (window.__rtFx) return;
        window.__rtFx = true;

        addEventListener("pointermove", function (e) {
          document.documentElement.style.setProperty("--mx", e.clientX + "px");
          document.documentElement.style.setProperty("--my", e.clientY + "px");
        });

        function reveal() {
          document.body.classList.remove("loaded");
          requestAnimationFrame(function () {
            requestAnimationFrame(function () {
              document.body.classList.add("loaded");
            });
          });
        }
        reveal();
      })();
    </script>
  </body>
</html>
