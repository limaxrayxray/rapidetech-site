---
// Contenu détaillé d'un service — UTILISÉ DEUX FOIS : pleine page
// (/services/<slug>/, indexable) et overlay sur l'accueil (même contenu,
// déjà dans le HTML au build → ouverture instantanée, zéro fetch).
import type { Service } from "@/lib/directus";

interface Props {
  service: Service;
  num: number;
  /** h1 sur la page dédiée, h2 dans l'overlay de l'accueil. */
  heading?: "h1" | "h2";
  ctaLabel: string;
  ctaHref: string;
}
const { service, num, heading = "h1", ctaLabel, ctaHref } = Astro.props;
const H = heading;
const numLabel = `/ ${String(num).padStart(2, "0")}`;
const paragraphs = (service.body || "")
  .split(/\n\s*\n/)
  .map((p) => p.trim())
  .filter(Boolean);
---

<article class="rt-svcpanel">
  <p class="rt-svcpanel-eyebrow">{numLabel} — Service</p>
  <H class="rt-svcpanel-title" id={`svc-title-${service.slug}`}>{service.title}</H>
  <p class="rt-svcpanel-intro">{service.description}</p>

  {paragraphs.map((p) => <p class="rt-svcpanel-body">{p}</p>)}

  {service.benefits.length > 0 && (
    <ul class="rt-svcpanel-benefits">
      {service.benefits.map((b) => (
        <li>
          <span class="rt-square" aria-hidden="true"></span>
          {b.value}
        </li>
      ))}
    </ul>
  )}

  {service.faq && service.faq.length > 0 && (
    <section class="rt-svcpanel-faq" aria-labelledby={`faq-title-${service.slug}`}>
      <h2 id={`faq-title-${service.slug}`}>Questions fréquentes</h2>
      {service.faq.map((item) => (
        <details>
          <summary>{item.question}</summary>
          <p>{item.answer}</p>
        </details>
      ))}
    </section>
  )}

  <a href={ctaHref} class="rt-svcpanel-cta">
    {ctaLabel} <span aria-hidden="true">→</span>
  </a>
</article>

<style>
  .rt-svcpanel-eyebrow {
    font-family: var(--font-mono);
    font-size: var(--text-label);
    letter-spacing: var(--tracking-eyebrow);
    text-transform: uppercase;
    color: var(--accent);
    margin: 0 0 20px;
  }
  .rt-svcpanel-title {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: clamp(38px, 5vw, 72px);
    line-height: var(--leading-display);
    letter-spacing: var(--tracking-display);
    text-transform: uppercase;
    color: var(--text-primary);
    margin: 0 0 20px;
  }
  .rt-svcpanel-intro {
    font-family: var(--font-body);
    font-size: var(--text-heading);
    line-height: var(--leading-body);
    color: var(--text-primary);
    max-width: 560px;
    margin: 0 0 28px;
  }
  .rt-svcpanel-body {
    font-family: var(--font-body);
    font-size: var(--text-body);
    line-height: var(--leading-body);
    color: var(--text-secondary);
    max-width: 560px;
    margin: 0 0 18px;
  }
  .rt-svcpanel-benefits {
    list-style: none;
    margin: 32px 0 0;
    padding: 24px 0 0;
    border-top: 1px solid var(--border-default);
    display: flex;
    flex-direction: column;
    gap: 12px;
  }
  .rt-svcpanel-benefits li {
    display: flex;
    align-items: baseline;
    gap: 12px;
    font-family: var(--font-mono);
    font-size: var(--text-ui);
    letter-spacing: 0.06em;
    color: var(--text-secondary);
  }
  .rt-square {
    width: 8px;
    height: 8px;
    background: var(--accent);
    flex-shrink: 0;
    transform: translateY(-1px);
  }
  .rt-svcpanel-faq {
    margin-top: 44px;
    padding-top: 28px;
    border-top: 1px solid var(--border-default);
    max-width: 680px;
  }
  .rt-svcpanel-faq h2 {
    margin: 0 0 18px;
    font-family: var(--font-display);
    font-size: var(--text-heading);
    text-transform: uppercase;
    letter-spacing: 0.02em;
  }
  .rt-svcpanel-faq details {
    border-bottom: 1px solid var(--border-default);
    padding: 16px 0;
  }
  .rt-svcpanel-faq summary {
    cursor: pointer;
    font-family: var(--font-body);
    font-size: var(--text-body-sm);
    font-weight: 600;
    color: var(--text-primary);
  }
  .rt-svcpanel-faq p {
    margin: 12px 0 0;
    font-family: var(--font-body);
    font-size: var(--text-body-sm);
    line-height: var(--leading-body);
    color: var(--text-secondary);
  }
  .rt-svcpanel-cta {
    margin-top: 40px;
    display: inline-flex;
    align-items: center;
    gap: 14px;
    background: var(--accent);
    color: var(--text-on-accent);
    font-family: var(--font-mono);
    font-size: var(--text-ui);
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    text-decoration: none;
    padding: 18px 30px;
    transition: background var(--dur-fast);
  }
  .rt-svcpanel-cta:hover {
    background: var(--accent-hover);
  }
</style>
