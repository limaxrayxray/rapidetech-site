---
import { getImage } from "astro:assets";
import Base from "@/layouts/Base.astro";
import Hero from "@/components/Hero.tsx";
import ServiceIcon from "@/components/ServiceIcon.tsx";
import { getHome, getServices, getDifferentiators, getAbout, getTestimonials, getSiteSettings, getPartners, assetUrl } from "@/lib/directus";

// Runs at BUILD time. Content is baked into static HTML.
const home = await getHome();
const services = await getServices();
const differentiators = await getDifferentiators();
const about = await getAbout();
const testimonials = await getTestimonials();
const siteSettings = await getSiteSettings();
const partners = await getPartners();

// IMAGE: on RAPATRIE + optimise l'asset Directus AU BUILD via getImage() — le
// HTML final ne contient qu'un chemin LOCAL (dist/_astro/...), jamais l'URL
// privée Directus. `inferSize` lit les dimensions d'origine (requis pour un
// asset distant). Si l'asset n'est pas joignable (Directus hors ligne, ou token
// de build pas encore configuré), on dégrade proprement → pas d'image, build OK.
async function localizeImage(
  fileId: string | null,
  width: number
): Promise<string | undefined> {
  if (!fileId) return undefined;
  try {
    const optimized = await getImage({
      src: assetUrl(fileId),
      width,
      format: "webp",
      inferSize: true,
    });
    return optimized.src;
  } catch {
    return undefined;
  }
}

const heroImageSrc = await localizeImage(home.hero_image, 1600);
const aboutPhotoSrc = await localizeImage(about.photo, 600);
const partnersWithLogo = await Promise.all(
  partners.map(async (p) => ({ ...p, logoSrc: await localizeImage(p.logo, 240) }))
);
---

<Base>
  {/* client:visible → la React island n'hydrate qu'au scroll. */}
  <Hero
    client:visible
    eyebrow={home.hero_eyebrow}
    title={home.hero_title}
    subtitle={home.hero_subtitle}
    ctaLabel={home.hero_cta_label}
    ctaHref={home.hero_cta_href}
    imageSrc={heroImageSrc}
  />

  <section class="mx-auto max-w-5xl px-6 py-20">
    <h2 class="mb-12 text-center text-3xl font-bold text-foreground">
      {home.services_title}
    </h2>
    <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {
        services.map((s) => (
          <article class="rounded-2xl border border-border bg-card p-6 transition-transform hover:-translate-y-1">
            <ServiceIcon name={s.icon} className="h-8 w-8 text-primary" />
            <h3 class="mt-4 text-lg font-semibold text-card-foreground">{s.title}</h3>
            <p class="mt-2 text-sm text-muted-foreground">{s.description}</p>
          </article>
        ))
      }
    </div>
  </section>

  <section class="mx-auto max-w-5xl px-6 py-20">
    <h2 class="mb-12 text-center text-3xl font-bold text-foreground">
      {home.differentiators_title}
    </h2>
    <div class="grid gap-6 sm:grid-cols-2">
      {
        differentiators.map((d) => (
          <article class="rounded-2xl border border-border bg-card p-8">
            <h3 class="text-lg font-semibold text-card-foreground">{d.title}</h3>
            <p class="mt-3 text-sm leading-relaxed text-muted-foreground">{d.description}</p>
          </article>
        ))
      }
    </div>
  </section>

  <section class="mx-auto max-w-5xl px-6 py-20">
    <h2 class="mb-12 text-center text-3xl font-bold text-foreground">
      Ce que nos clients disent
    </h2>
    <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {
        testimonials.map((t) => (
          <article class="flex flex-col rounded-2xl border border-border bg-card p-6">
            {t.rating && (
              <div class="mb-3 flex gap-0.5 text-accent" aria-label={`${t.rating} sur 5`}>
                {Array.from({ length: t.rating }).map(() => (
                  <span aria-hidden="true">★</span>
                ))}
              </div>
            )}
            <p class="flex-1 text-sm leading-relaxed text-card-foreground">“{t.quote}”</p>
            <div class="mt-4">
              <p class="text-sm font-semibold text-card-foreground">{t.name}</p>
              <p class="text-xs text-muted-foreground">{t.detail}</p>
            </div>
          </article>
        ))
      }
    </div>
    {siteSettings.google_reviews_url && siteSettings.google_reviews_url !== "#" && (
      <div class="mt-12 text-center">
        <a
          href={siteSettings.google_reviews_url}
          target="_blank"
          rel="noopener"
          class="inline-flex items-center rounded-full bg-primary px-6 py-3 text-sm font-semibold text-primary-foreground transition-opacity hover:opacity-90"
        >
          Voir tous nos avis sur Google
        </a>
      </div>
    )}
  </section>

  <section class="mx-auto max-w-5xl px-6 py-20">
    <div class="flex flex-col items-center gap-12 md:flex-row md:items-start">
      {aboutPhotoSrc && (
        <div class="shrink-0">
          <img
            src={aboutPhotoSrc}
            alt={about.name}
            width="240"
            height="240"
            class="rounded-full object-cover shadow-lg"
            style="width:240px;height:240px;"
          />
        </div>
      )}
      <div class="flex-1">
        <p class="text-sm font-semibold uppercase tracking-widest text-primary">
          Qui je suis
        </p>
        <h2 class="mt-2 text-3xl font-bold text-foreground">{about.name}</h2>
        <p class="mt-1 text-base text-muted-foreground">{about.role}</p>
        <p class="mt-4 leading-relaxed text-foreground">{about.bio}</p>
        {about.values?.length > 0 && (
          <ul class="mt-6 space-y-2">
            {about.values.map((v) => (
              <li class="flex items-start gap-2 text-sm text-muted-foreground">
                <span class="mt-1 h-2 w-2 shrink-0 rounded-full bg-primary" />
                {v.value}
              </li>
            ))}
          </ul>
        )}
      </div>
    </div>
  </section>

  {
    partnersWithLogo.length > 0 && (
      <section class="mx-auto max-w-5xl px-6 py-20">
        <h2 class="text-center text-3xl font-bold text-foreground">{home.partners_title}</h2>
        {home.partners_intro && (
          <p class="mx-auto mt-4 max-w-2xl text-center text-muted-foreground">
            {home.partners_intro}
          </p>
        )}
        <div class="mt-12 grid grid-cols-2 items-center gap-8 sm:grid-cols-3 lg:grid-cols-4">
          {partnersWithLogo.map((p) => {
            const inner = p.logoSrc ? (
              <img
                src={p.logoSrc}
                alt={p.name}
                class="max-h-12 w-auto opacity-70 transition-opacity hover:opacity-100"
                loading="lazy"
              />
            ) : (
              <span class="text-sm font-medium text-muted-foreground">{p.name}</span>
            );
            return (
              <div class="flex items-center justify-center">
                {p.url ? (
                  <a href={p.url} target="_blank" rel="noopener" aria-label={p.name}>
                    {inner}
                  </a>
                ) : (
                  inner
                )}
              </div>
            );
          })}
        </div>
      </section>
    )
  }

  <section class="mx-auto max-w-5xl px-6 py-20">
    <div class="rounded-3xl border border-border bg-card px-6 py-16 text-center">
      <h2 class="text-3xl font-bold text-foreground sm:text-4xl">{home.cta_final_title}</h2>
      {home.cta_final_body && (
        <p class="mx-auto mt-4 max-w-2xl text-muted-foreground">{home.cta_final_body}</p>
      )}
      <a
        href={home.cta_final_href}
        class="mt-8 inline-flex items-center rounded-xl bg-primary px-7 py-3.5 text-base font-semibold text-primary-foreground shadow-lg shadow-primary/25 transition-transform hover:scale-[1.03]"
      >
        {home.cta_final_label}
      </a>
    </div>
  </section>
</Base>
