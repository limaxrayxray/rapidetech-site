# Config du relais formulaire → courriel (deploy/lead-mailer.mjs).
# À copier vers /etc/rapidetech-leads.env (chmod 600) et compléter.
# La clé Brevo : compte gratuit (300 courriels/jour) → SMTP & API → générer
# une clé API. L'expéditeur (LEAD_FROM) doit être validé dans Brevo
# (Senders & domains) — idéalement le domaine rapidetech.ca au complet.

BREVO_API_KEY=xkeysib-REMPLACER
LEAD_TO=amartin@rapidetech.ca
LEAD_FROM=site@rapidetech.ca
LEAD_FROM_NAME=Site Rapidetech

# Optionnel (défauts sensés)
#LEAD_BIND=127.0.0.1
#LEAD_PORT=8788
#LEAD_LOG=/var/log/rapidetech-leads.jsonl
#LEAD_REDIRECT=/merci/
