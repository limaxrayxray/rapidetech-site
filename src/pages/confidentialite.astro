---
// Politique de confidentialité (Loi 25) — contenu 100 % Directus (singleton
// `privacy`, fallback complet). Convention du corps : blocs séparés par une
// ligne vide ; « ## Titre » = intertitre ; bloc dont chaque ligne commence
// par « - » = liste à puces ; sinon paragraphe. Zéro JS.
import Base from "@/layouts/Base.astro";
import { getPrivacy, getSiteSettings } from "@/lib/directus";

const privacy = await getPrivacy();
const settings = await getSiteSettings();
const title = `${privacy.title} — ${settings.company_name}`;
const description =
  "Comment Rapidetech recueille, utilise et protège vos renseignements personnels (Loi 25).";

type Block =
  | { kind: "h2"; text: string }
  | { kind: "ul"; items: string[] }
  | { kind: "p"; text: string };

const blocks: Block[] = (privacy.body || "")
  .split(/\n\s*\n/)
  .map((b) => b.trim())
  .filter(Boolean)
  .map((b) => {
    if (b.startsWith("## ")) return { kind: "h2", text: b.slice(3).trim() };
    const lines = b.split("\n").map((l) => l.trim());
    if (lines.every((l) => l.startsWith("- ")))
      return { kind: "ul", items: lines.map((l) => l.slice(2).trim()) };
    return { kind: "p", text: lines.join(" ") };
  });
---

<Base title={title} description={description}>
  <main class="rt-legal">
    <nav class="rt-legal-back" aria-label="Fil d'Ariane">
      <a href="/">← {settings.company_name}</a>
    </nav>

    <p class="rt-legal-eyebrow">/ Légal</p>
    <h1 class="rt-legal-title">{privacy.title}</h1>
    <p class="rt-legal-updated">Dernière mise à jour : {privacy.updated}</p>

    {
      blocks.map((block) =>
        block.kind === "h2" ? (
          <h2 class="rt-legal-h2">{block.text}</h2>
        ) : block.kind === "ul" ? (
          <ul class="rt-legal-ul">
            {block.items.map((item) => (
              <li>
                <span class="rt-square" aria-hidden="true"></span>
                {item}
              </li>
            ))}
          </ul>
        ) : (
          <p class="rt-legal-p">{block.text}</p>
        )
      )
    }
  </main>
</Base>

<style>
  .rt-legal {
    position: relative;
    z-index: 2;
    padding: var(--section-pad);
    max-width: 820px;
  }
  .rt-legal-back {
    margin-bottom: 48px;
  }
  .rt-legal-back a {
    font-family: var(--font-mono);
    font-size: var(--text-label);
    letter-spacing: var(--tracking-label);
    text-transform: uppercase;
    color: var(--text-secondary);
    text-decoration: none;
    transition: color var(--dur-fast);
  }
  .rt-legal-back a:hover {
    color: var(--text-primary);
  }
  .rt-legal-eyebrow {
    font-family: var(--font-mono);
    font-size: var(--text-label);
    letter-spacing: var(--tracking-eyebrow);
    text-transform: uppercase;
    color: var(--accent);
    margin: 0 0 20px;
  }
  .rt-legal-title {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: clamp(34px, 4.5vw, 60px);
    line-height: var(--leading-display);
    letter-spacing: var(--tracking-display);
    text-transform: uppercase;
    color: var(--text-primary);
    margin: 0 0 12px;
  }
  .rt-legal-updated {
    font-family: var(--font-mono);
    font-size: var(--text-micro);
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--text-tertiary);
    margin: 0 0 48px;
  }
  .rt-legal-h2 {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 22px;
    letter-spacing: 0.02em;
    text-transform: uppercase;
    color: var(--text-primary);
    margin: 44px 0 14px;
  }
  .rt-legal-p {
    font-family: var(--font-body);
    font-size: var(--text-body);
    line-height: var(--leading-body);
    color: var(--text-secondary);
    max-width: 640px;
    margin: 0 0 16px;
  }
  .rt-legal-ul {
    list-style: none;
    margin: 0 0 16px;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 10px;
    max-width: 640px;
  }
  .rt-legal-ul li {
    display: flex;
    align-items: baseline;
    gap: 12px;
    font-family: var(--font-body);
    font-size: var(--text-body);
    line-height: var(--leading-body);
    color: var(--text-secondary);
  }
  .rt-square {
    width: 8px;
    height: 8px;
    background: var(--accent);
    flex-shrink: 0;
    transform: translateY(-1px);
  }
</style>
