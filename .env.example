# Directus connection (read-only token recommended for build).
# Leave blank to build against the static fallbacks in src/lib/directus.ts.
DIRECTUS_URL=http://localhost:8055
DIRECTUS_TOKEN=

# Cloudflare Turnstile (anti-spam formulaire). Site key PUBLIQUE — le widget
# n'est rendu que si la valeur est présente au build. À définir UNIQUEMENT
# pour le build du domaine root (prod) ; laisser vide pour les autres hosts
# (préprod/local) → leur formulaire reste sans widget.
# Le secret correspondant va dans ~/rapidetech-leads.env (TURNSTILE_SECRET).
PUBLIC_TURNSTILE_SITE_KEY=
