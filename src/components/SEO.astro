---
// Bloc de métadonnées SEO réutilisable, rendu dans le <head> du layout.
// Chaîne de fallback (règle « contenu → Directus ») :
//   props de la page (ex. seo_title d'un service)
//   → site_settings.meta_title / meta_description (Directus, via fillEmpty)
//   → FALLBACK_SITE_SETTINGS (directus.ts) si Directus est hors ligne/vide.
// Base.astro fournit les valeurs Directus ; une page surcharge via ses props.

interface Props {
  title: string;
  description: string;
  /** og:site_name — vient de site_settings.company_name. */
  siteName: string;
  /** Type Open Graph (« website » par défaut, « article » pour du contenu). */
  type?: string;
  /** Image de partage — chemin local (public/) ou URL absolue. */
  image?: string;
  /** true → meta robots noindex (pages utilitaires, ex. /merci/). */
  noindex?: boolean;
}

const {
  title,
  description,
  siteName,
  type = "website",
  image = "/og.png",
  noindex = false,
} = Astro.props;

// En pré-prod (SITE_ENV=preprod dans le .env de build), TOUT est noindex —
// dev.galx.ca ne doit jamais se retrouver dans Google. Voir aussi robots.txt.ts.
const blockRobots = noindex || import.meta.env.SITE_ENV === "preprod";
const canonical = new URL(Astro.url.pathname, Astro.site);
const ogImage = new URL(image, Astro.site);
---

<title>{title}</title>
<meta name="description" content={description} />
{blockRobots && <meta name="robots" content="noindex, nofollow" />}
<link rel="canonical" href={canonical} />
<!-- Open Graph / partage social -->
<meta property="og:type" content={type} />
<meta property="og:site_name" content={siteName} />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:url" content={canonical} />
<meta property="og:image" content={ogImage} />
<meta property="og:locale" content="fr_CA" />
<meta name="twitter:card" content="summary_large_image" />
