---
import { getImage } from "astro:assets";
import Base from "@/layouts/Base.astro";
import Hero from "@/components/Hero.tsx";
import Marquee from "@/components/Marquee.astro";
import SectionHeader from "@/components/SectionHeader.astro";
import ServiceRow from "@/components/ServiceRow.astro";
import TestimonialCard from "@/components/TestimonialCard.astro";
import Button from "@/components/Button.astro";
import {
  getHome,
  getServices,
  getDifferentiators,
  getAbout,
  getTestimonials,
  getSiteSettings,
  getPartners,
  assetUrl,
} from "@/lib/directus";

// Runs at BUILD time. Content is baked into static HTML.
const home = await getHome();
const services = await getServices();
const differentiators = await getDifferentiators();
const about = await getAbout();
const testimonials = await getTestimonials();
const siteSettings = await getSiteSettings();
const partners = await getPartners();

// IMAGE: on RAPATRIE + optimise l'asset Directus AU BUILD via getImage() — le
// HTML final ne contient qu'un chemin LOCAL (dist/_astro/...), jamais l'URL
// privée Directus. `inferSize` lit les dimensions d'origine (requis pour un
// asset distant). Si l'asset n'est pas joignable (Directus hors ligne, ou token
// de build pas encore configuré), on dégrade proprement → pas d'image, build OK.
async function localizeImage(
  fileId: string | null,
  width: number
): Promise<string | undefined> {
  if (!fileId) return undefined;
  try {
    const optimized = await getImage({
      src: assetUrl(fileId),
      width,
      format: "webp",
      inferSize: true,
    });
    return optimized.src;
  } catch {
    return undefined;
  }
}

const aboutPhotoSrc = await localizeImage(about.photo, 600);
const partnersWithLogo = await Promise.all(
  partners.map(async (p) => ({ ...p, logoSrc: await localizeImage(p.logo, 240) }))
);

const scrambleWords = home.hero_scramble_words.map((w) => w.value);
const marqueeItems = home.marquee_items.map((m) => m.value);
const cities = siteSettings.cities.map((c) => c.value);
---

<Base>
  {/* client:idle → hydrate dès que le main thread est libre (scramble,
      horloge, ping). Les reveals d'entrée sont en CSS pur, donc le hero
      est complet visuellement avant même l'hydratation. */}
  <Hero
    client:idle
    eyebrow={home.hero_eyebrow}
    titleLine1={home.hero_title_line1}
    titleGhost={home.hero_title_ghost}
    scrambleWords={scrambleWords}
    titleLine3={home.hero_title_line3}
    subtitle={home.hero_subtitle}
    ctaLabel={home.hero_cta_label}
    ctaHref={home.hero_cta_href}
    statusMessage={siteSettings.status_message}
    coordinates={siteSettings.coordinates}
    city={siteSettings.city}
  />

  <Marquee items={marqueeItems} />

  {/* ── SERVICES ── */}
  <section class="rt-section" id="services">
    <SectionHeader title={home.services_title} count={services.length} />
    {services.map((s, i) => (
      <ServiceRow
        num={i + 1}
        title={s.title}
        desc={s.description}
        href={home.cta_final_href}
      />
    ))}
  </section>

  {/* ── ANCRAGE LOCAL (villes + avis Google) ── */}
  <section class="rt-local">
    <div class="rt-local-badge">
      <div class="rt-local-stars">
        {siteSettings.google_rating}
        <span class="rt-local-s" aria-hidden="true">★★★★★</span>
      </div>
      <p class="rt-local-src">
        Avis Google{siteSettings.google_reviews_count != null && (
          <Fragment> — {siteSettings.google_reviews_count} avis vérifiés</Fragment>
        )}
      </p>
    </div>
    <div class="rt-local-cities">
      <h3>{home.local_title}</h3>
      <p class="rt-cities">
        {cities.map((c, i) => (i === 0 ? <span><b>{c}</b></span> : <span>{c}</span>))}
      </p>
    </div>
  </section>

  {/* ── DIFFÉRENCIATEURS ── */}
  <section class="rt-section" id="approche">
    <SectionHeader
      title={home.differentiators_title}
      count={differentiators.length}
    />
    <div class="rt-diff-grid">
      {differentiators.map((d, i) => (
        <article class="rt-diff">
          <span class="rt-diff-num">/ {String(i + 1).padStart(2, "0")}</span>
          <h3>{d.title}</h3>
          <p>{d.description}</p>
        </article>
      ))}
    </div>
  </section>

  {/* ── TÉMOIGNAGES ── */}
  <section class="rt-section">
    <SectionHeader title={home.testimonials_title} count={testimonials.length} />
    <div class="rt-testim-grid">
      {testimonials.map((t, i) => (
        <TestimonialCard
          quote={t.quote}
          author={t.name}
          role={t.detail}
          index={i + 1}
          rating={t.rating}
        />
      ))}
    </div>
    {siteSettings.google_reviews_url && siteSettings.google_reviews_url !== "#" && (
      <div class="rt-testim-more">
        <Button href={siteSettings.google_reviews_url} variant="ghost" target="_blank" rel="noopener">
          Voir tous nos avis sur Google
        </Button>
      </div>
    )}
  </section>

  {/* ── À PROPOS ── */}
  <section class="rt-section" id="a-propos">
    <div class="rt-about">
      {aboutPhotoSrc && (
        <div class="rt-about-photo">
          <img
            src={aboutPhotoSrc}
            alt={about.name}
            width="280"
            height="280"
            loading="lazy"
          />
        </div>
      )}
      <div class="rt-about-body">
        <p class="rt-eyebrow">{home.about_title}</p>
        <h2>{about.name}</h2>
        <p class="rt-about-role">{about.role}</p>
        <p class="rt-about-bio">{about.bio}</p>
        {about.values?.length > 0 && (
          <ul class="rt-about-values">
            {about.values.map((v) => (
              <li>
                <span class="rt-square" aria-hidden="true"></span>
                {v.value}
              </li>
            ))}
          </ul>
        )}
      </div>
    </div>
  </section>

  {/* ── PARTENAIRES ── */}
  {partnersWithLogo.length > 0 && (
    <section class="rt-section">
      <SectionHeader title={home.partners_title} count={partnersWithLogo.length} />
      {home.partners_intro && <p class="rt-partners-intro">{home.partners_intro}</p>}
      <div class="rt-partners-grid">
        {partnersWithLogo.map((p) => {
          const inner = p.logoSrc ? (
            <img src={p.logoSrc} alt={p.name} loading="lazy" />
          ) : (
            <span class="rt-partner-name">{p.name}</span>
          );
          return (
            <div class="rt-partner">
              {p.url ? (
                <a href={p.url} target="_blank" rel="noopener" aria-label={p.name}>
                  {inner}
                </a>
              ) : (
                inner
              )}
            </div>
          );
        })}
      </div>
    </section>
  )}

  {/* ── CTA FINAL ── */}
  <section class="rt-cta-final" id="contact">
    <p class="rt-eyebrow">// Contact</p>
    <h2>{home.cta_final_title}</h2>
    {home.cta_final_body && <p class="rt-cta-body">{home.cta_final_body}</p>}
    <Button href={home.cta_final_href} size="lg">{home.cta_final_label}</Button>
  </section>
</Base>

<style>
  .rt-section {
    position: relative;
    z-index: 2;
    padding: var(--section-pad);
  }

  /* Eyebrow mono (réutilisé À propos + CTA final) */
  .rt-eyebrow {
    font-family: var(--font-mono);
    font-size: var(--text-label);
    letter-spacing: var(--tracking-eyebrow);
    text-transform: uppercase;
    color: var(--accent);
    margin: 0 0 20px;
  }

  /* ── Ancrage local ── */
  .rt-local {
    position: relative;
    z-index: 2;
    border-top: 1px solid var(--border-default);
    padding: 56px var(--gutter-page) 64px;
    display: grid;
    grid-template-columns: 320px 1fr;
    gap: 48px;
    align-items: start;
    background: var(--surface-raised);
  }
  .rt-local-stars {
    display: flex;
    align-items: center;
    gap: 10px;
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 28px;
    color: var(--text-primary);
  }
  .rt-local-s {
    color: var(--accent);
    font-size: 18px;
    letter-spacing: 3px;
  }
  .rt-local-src {
    font-family: var(--font-mono);
    font-size: var(--text-micro);
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--text-tertiary);
    margin: 14px 0 0;
  }
  .rt-local-cities h3 {
    font-family: var(--font-mono);
    font-size: var(--text-label);
    font-weight: 400;
    letter-spacing: var(--tracking-eyebrow);
    text-transform: uppercase;
    color: var(--accent);
    margin: 0 0 20px;
    display: flex;
    align-items: center;
    gap: 14px;
  }
  .rt-local-cities h3::after {
    content: "";
    flex: 1;
    height: 1px;
    background: var(--border-default);
  }
  .rt-cities {
    display: flex;
    flex-wrap: wrap;
    gap: 8px 0;
    font-family: var(--font-body);
    font-size: 14px;
    color: var(--text-secondary);
    line-height: 1.6;
    margin: 0;
  }
  .rt-cities span {
    white-space: nowrap;
  }
  .rt-cities span::after {
    content: "✧";
    color: var(--rt-line-hi);
    margin: 0 14px;
    font-size: 10px;
  }
  .rt-cities span:last-child::after {
    content: "";
    margin: 0;
  }
  .rt-cities b {
    color: var(--text-primary);
    font-weight: 500;
  }
  @media (max-width: 900px) {
    .rt-local {
      grid-template-columns: 1fr;
      gap: 32px;
    }
  }

  /* ── Différenciateurs ── */
  .rt-diff-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1px;
    background: var(--border-default);
    border: 1px solid var(--border-default);
  }
  .rt-diff {
    background: var(--surface-card);
    padding: 36px 32px;
    transition: background 0.25s;
  }
  .rt-diff:hover {
    background: #1a1a19;
  }
  .rt-diff-num {
    font-family: var(--font-mono);
    font-size: var(--text-label);
    letter-spacing: var(--tracking-label);
    color: var(--accent);
  }
  .rt-diff h3 {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 22px;
    line-height: 1.1;
    letter-spacing: -0.01em;
    text-transform: uppercase;
    color: var(--text-primary);
    margin: 18px 0 12px;
  }
  .rt-diff p {
    font-family: var(--font-body);
    font-size: var(--text-body-sm);
    line-height: var(--leading-desc);
    color: var(--text-secondary);
    margin: 0;
  }
  @media (max-width: 720px) {
    .rt-diff-grid {
      grid-template-columns: 1fr;
    }
  }

  /* ── Témoignages ── */
  .rt-testim-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 20px;
  }
  .rt-testim-more {
    margin-top: 48px;
    text-align: center;
  }
  @media (max-width: 1000px) {
    .rt-testim-grid {
      grid-template-columns: 1fr;
      max-width: 560px;
    }
  }

  /* ── À propos ── */
  .rt-about {
    display: flex;
    gap: 64px;
    align-items: flex-start;
  }
  .rt-about-photo img {
    width: 280px;
    height: 280px;
    object-fit: cover;
    /* Traitement froid/contrasté prescrit par le design system. */
    filter: grayscale(1) contrast(1.1);
    border: 1px solid var(--border-default);
    display: block;
  }
  .rt-about-body h2 {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: var(--text-title);
    line-height: 1;
    letter-spacing: var(--tracking-display);
    text-transform: uppercase;
    color: var(--text-primary);
    margin: 0 0 8px;
  }
  .rt-about-role {
    font-family: var(--font-mono);
    font-size: var(--text-label);
    letter-spacing: var(--tracking-label);
    text-transform: uppercase;
    color: var(--text-tertiary);
    margin: 0 0 24px;
  }
  .rt-about-bio {
    font-family: var(--font-body);
    font-size: var(--text-body);
    line-height: var(--leading-body);
    color: var(--text-secondary);
    max-width: 560px;
    margin: 0;
  }
  .rt-about-values {
    list-style: none;
    margin: 28px 0 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }
  .rt-about-values li {
    display: flex;
    align-items: baseline;
    gap: 12px;
    font-family: var(--font-mono);
    font-size: 12px;
    letter-spacing: 0.06em;
    color: var(--text-secondary);
  }
  .rt-square {
    width: 8px;
    height: 8px;
    background: var(--accent);
    flex-shrink: 0;
    transform: translateY(-1px);
  }
  @media (max-width: 900px) {
    .rt-about {
      flex-direction: column;
      gap: 40px;
    }
  }

  /* ── Partenaires ── */
  .rt-partners-intro {
    font-family: var(--font-body);
    font-size: var(--text-body-sm);
    line-height: var(--leading-desc);
    color: var(--text-secondary);
    max-width: 480px;
    margin: -24px 0 48px;
  }
  .rt-partners-grid {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 1px;
    background: var(--border-default);
    border: 1px solid var(--border-default);
  }
  .rt-partner {
    background: var(--surface-card);
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 32px 24px;
    min-height: 110px;
  }
  .rt-partner img {
    max-height: 44px;
    width: auto;
    /* Logos en niveaux de gris sur charbon — couleur au survol. */
    filter: grayscale(1) brightness(1.4);
    opacity: 0.6;
    transition: opacity 0.25s, filter 0.25s;
  }
  .rt-partner:hover img {
    opacity: 1;
    filter: none;
  }
  .rt-partner-name {
    font-family: var(--font-mono);
    font-size: var(--text-label);
    letter-spacing: var(--tracking-label);
    text-transform: uppercase;
    color: var(--text-secondary);
  }
  @media (max-width: 720px) {
    .rt-partners-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  /* ── CTA final ── */
  .rt-cta-final {
    position: relative;
    z-index: 2;
    border-top: 1px solid var(--border-default);
    padding: 110px var(--gutter-page) 120px;
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
  }
  .rt-cta-final h2 {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: clamp(38px, 5.4vw, 84px);
    line-height: var(--leading-display);
    letter-spacing: var(--tracking-display);
    text-transform: uppercase;
    color: var(--text-primary);
    margin: 0 0 28px;
    max-width: 18ch;
  }
  .rt-cta-body {
    font-family: var(--font-body);
    font-size: var(--text-body);
    line-height: var(--leading-body);
    color: var(--text-secondary);
    max-width: 480px;
    margin: 0 0 44px;
  }
</style>
