---
import "@/styles/global.css";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import { getSiteSettings } from "@/lib/directus";

interface Props {
  title?: string;
  description?: string;
  /** true → meta robots noindex (pages utilitaires, ex. /merci/). */
  noindex?: boolean;
}

// Réglages globaux (build time). meta_title / meta_description pilotent le SEO
// par défaut ; une page peut toujours surcharger via les props title/description.
const settings = await getSiteSettings();

const {
  title = settings.meta_title,
  description = settings.meta_description,
  noindex = false,
} = Astro.props;

// En pré-prod (SITE_ENV=preprod dans le .env de build), TOUT est noindex —
// dev.galx.ca ne doit jamais se retrouver dans Google. Voir aussi robots.txt.ts.
const blockRobots = noindex || import.meta.env.SITE_ENV === "preprod";
const canonical = new URL(Astro.url.pathname, Astro.site);
const ogImage = new URL("/og.png", Astro.site);
---

<!doctype html>
<html lang="fr-CA" class="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>
    {blockRobots && <meta name="robots" content="noindex, nofollow" />}
    <link rel="canonical" href={canonical} />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <!-- Open Graph / partage social -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={settings.company_name} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:locale" content="fr_CA" />
    <meta name="twitter:card" content="summary_large_image" />
    <!-- Fonts display critiques (le hero est above-the-fold). -->
    <link
      rel="preload"
      href="/fonts/ClashDisplay-Semibold.woff"
      as="font"
      type="font/woff"
      crossorigin
    />
    <link
      rel="preload"
      href="/fonts/GeneralSans-Regular.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />
    <!-- Gate no-JS : les états « cachés avant reveal » n'existent que sous
         html.js — sans JavaScript, tout le contenu est visible d'emblée. -->
    <script is:inline>
      document.documentElement.classList.add("js");
    </script>
  </head>
  <body>
    <!-- Spotlight vert qui suit le curseur (texture signature CIRCUIT). -->
    <div class="rt-spot" aria-hidden="true"></div>
    <Header settings={settings} />
    <slot />
    <Footer settings={settings} />

    <!-- Effets globaux CIRCUIT : suivi du pointeur (spotlight + grille du
         hero via --mx/--my) et déclenchement des reveals (body.loaded). -->
    <script is:inline>
      (function () {
        if (window.__rtFx) return;
        window.__rtFx = true;

        addEventListener("pointermove", function (e) {
          document.documentElement.style.setProperty("--mx", e.clientX + "px");
          document.documentElement.style.setProperty("--my", e.clientY + "px");
        });

        function reveal() {
          document.body.classList.remove("loaded");
          requestAnimationFrame(function () {
            requestAnimationFrame(function () {
              document.body.classList.add("loaded");
            });
          });
        }
        reveal();
      })();
    </script>
  </body>
</html>
