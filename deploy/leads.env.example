# Config du relais formulaire → courriel (deploy/lead-mailer.mjs).
# - Mode SANS ROOT (VPS CloudPanel, le nôtre) : copier vers ~/rapidetech-leads.env
#   (chmod 600) et DÉCOMMENTER LEAD_LOG ci-dessous (/var/log n'est pas accessible).
#   Voir lead-mailer-watchdog.sh pour l'installation cron complète.
# - Mode systemd (si on a root un jour) : copier vers /etc/rapidetech-leads.env.
# La clé : tableau de bord SMTP2GO → Settings → API Keys → générer une clé
# avec la permission « Emails ». LEAD_FROM doit être un expéditeur/domaine
# déjà vérifié dans SMTP2GO (Sender domains).

SMTP2GO_API_KEY=api-cccc
LEAD_TO=amartin@rapidetech.ca
LEAD_FROM=info@rapidetech.ca
LEAD_FROM_NAME=Site Rapidetech

# Mode sans root : journal des leads dans le HOME (décommenter et ajuster)
#LEAD_LOG=/home/galx-dev-ssh/rapidetech-leads.jsonl

# Optionnel (défauts sensés)
#LEAD_BIND=127.0.0.1
#LEAD_PORT=8788
#LEAD_REDIRECT=/merci/
