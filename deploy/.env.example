# --- Postgres ---
DB_DATABASE=directus
DB_USER=directus
DB_PASSWORD=change-me-long-random

# --- Directus secrets (génère-les : openssl rand -hex 32) ---
DIRECTUS_KEY=replace-with-openssl-rand-hex-32
DIRECTUS_SECRET=replace-with-openssl-rand-hex-32

# URL d'accès admin (Tailscale recommandé), p.ex. http://cms.ton-tailnet.ts.net:8055
# ou http://100.x.y.z:8055
DIRECTUS_PUBLIC_URL=http://100.x.y.z:8055

# Compte admin créé au premier démarrage
ADMIN_EMAIL=alex@rapidetech.ca
ADMIN_PASSWORD=change-me-strong
